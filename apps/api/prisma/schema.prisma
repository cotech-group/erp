generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────
// Auth & Users
// ──────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Argon2id hash
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  isActive  Boolean  @default(true) @map("is_active")
  mfaEnabled Boolean @default(false) @map("mfa_enabled")
  odooUserId Int?    @map("odoo_user_id") // mapping vers Odoo

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  sessions      Session[]
  auditLogs     AuditLog[]
  mediaFiles    MediaFile[]
  documents     Document[]
  docVersions   DocumentVersion[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // admin, editor, viewer, rh, finance...
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  userRoles   UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id       String @id @default(uuid())
  resource String // media, documents, workflow, users...
  action   String // create, read, update, delete, validate...

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now()) @map("assigned_at")

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ──────────────────────────────────────
// Sessions & Tokens
// ──────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  replacedBy String? @map("replaced_by") // token rotation chain

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ──────────────────────────────────────
// Audit
// ──────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String   // login, logout, create, update, delete, validate...
  resource  String?  // users, media, documents, workflow...
  resourceId String? @map("resource_id")
  details   Json?
  ipAddress String?  @map("ip_address")
  traceId   String?  @map("trace_id")

  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ──────────────────────────────────────
// Media
// ──────────────────────────────────────

enum MediaStatus {
  DRAFT
  PROCESSING
  PUBLISHED
  ARCHIVED

  @@map("media_status")
}

enum MediaType {
  VIDEO
  AUDIO
  IMAGE
  DOCUMENT

  @@map("media_type")
}

model MediaFile {
  id            String      @id @default(uuid())
  title         String
  description   String?
  mediaType     MediaType   @map("media_type")
  status        MediaStatus @default(DRAFT)

  // Stockage S3
  bucket        String
  objectKey     String      @map("object_key")
  originalName  String      @map("original_name")
  mimeType      String      @map("mime_type")
  size          BigInt       // taille en octets
  checksum      String?     // SHA-256

  // Metadonnees techniques
  metadata      Json?       // duree, resolution, codec, etc.

  // Relations
  uploadedById  String      @map("uploaded_by_id")
  uploadedBy    User        @relation(fields: [uploadedById], references: [id])

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@index([uploadedById])
  @@index([status])
  @@index([mediaType])
  @@index([createdAt])
  @@map("media_files")
}

// ──────────────────────────────────────
// GED (Gestion Electronique de Documents)
// ──────────────────────────────────────

enum DocumentStatus {
  DRAFT
  ACTIVE
  ARCHIVED

  @@map("document_status")
}

model Document {
  id            String         @id @default(uuid())
  title         String
  description   String?
  classification String?       // categorie/domaine metier
  tags          String[]       @default([])
  status        DocumentStatus @default(DRAFT)

  // Fichier courant (derniere version)
  currentVersionId String?     @unique @map("current_version_id")
  currentVersion   DocumentVersion? @relation("CurrentVersion", fields: [currentVersionId], references: [id])

  // Droits d'acces documentaires (simplifies pour MVP)
  isPublic      Boolean        @default(false) @map("is_public")

  createdById   String         @map("created_by_id")
  createdBy     User           @relation(fields: [createdById], references: [id])

  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  versions      DocumentVersion[] @relation("DocumentVersions")

  @@index([createdById])
  @@index([status])
  @@index([classification])
  @@index([createdAt])
  @@map("documents")
}

model DocumentVersion {
  id            String   @id @default(uuid())
  documentId    String   @map("document_id")
  versionNumber Int      @map("version_number")
  comment       String?  // description du changement

  // Stockage S3
  bucket        String
  objectKey     String   @map("object_key")
  originalName  String   @map("original_name")
  mimeType      String   @map("mime_type")
  size          BigInt
  checksum      String?  // SHA-256

  uploadedById  String   @map("uploaded_by_id")
  uploadedBy    User     @relation(fields: [uploadedById], references: [id])

  createdAt     DateTime @default(now()) @map("created_at")

  document      Document @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  currentOf     Document? @relation("CurrentVersion")

  @@unique([documentId, versionNumber])
  @@index([documentId])
  @@map("document_versions")
}
